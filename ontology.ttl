@prefix : <http://scimantic.io/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://scimantic.io/> .

<http://scimantic.io/> rdf:type owl:Ontology ;
                        <http://purl.org/dc/terms/description> "A minimal domain ontology for representing the scientific method as provenance chains."@en ;
                        <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                        <http://purl.org/dc/terms/title> "Scimantic Ontology"@en ;
                        rdfs:seeAlso <http://www.w3.org/ns/prov#> ,
                                     <http://www.w3.org/ns/urref#> ;
                        owl:versionInfo "0.1.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://scimantic.io/expectedOutcome
:expectedOutcome rdf:type owl:ObjectProperty ;
                 rdfs:domain :Design ;
                 rdfs:range :Hypothesis ;
                 rdfs:label "expected outcome"@en .


###  http://scimantic.io/hasUncertainty
:hasUncertainty rdf:type owl:ObjectProperty ;
                rdfs:domain <http://www.w3.org/ns/prov#Entity> ;
                rdfs:range <http://www.w3.org/ns/urref#UncertaintyEntity> ;
                rdfs:comment "Links an entity to its uncertainty model."@en ;
                rdfs:label "has uncertainty"@en .


###  http://scimantic.io/parameter
:parameter rdf:type owl:ObjectProperty ;
           rdfs:domain :Design ;
           rdfs:range :Parameter ;
           rdfs:label "parameter"@en .


#################################################################
#    Data properties
#################################################################

###  http://scimantic.io/accessLevel
:accessLevel rdf:type owl:DatatypeProperty ;
             rdfs:domain <http://www.nanopub.org/nschema#Nanopublication> ;
             rdfs:range xsd:string ;
             rdfs:comment "Publishing scope (e.g., local, institutional, public)."@en ;
             rdfs:label "access level"@en .


###  http://scimantic.io/codeRepository
:codeRepository rdf:type owl:DatatypeProperty ;
                rdfs:domain <http://www.w3.org/ns/prov#SoftwareAgent> ;
                rdfs:range xsd:anyURI ;
                rdfs:label "code repository"@en .


###  http://scimantic.io/commitHash
:commitHash rdf:type owl:DatatypeProperty ;
            rdfs:domain <http://www.w3.org/ns/prov#SoftwareAgent> ;
            rdfs:range xsd:string ;
            rdfs:label "commit hash"@en .


###  http://scimantic.io/method
:method rdf:type owl:DatatypeProperty ;
        rdfs:domain :Design ;
        rdfs:range xsd:string ;
        rdfs:label "method"@en .


###  http://scimantic.io/publishable
:publishable rdf:type owl:DatatypeProperty ;
             rdfs:domain <http://www.nanopub.org/nschema#Nanopublication> ;
             rdfs:range xsd:boolean ;
             rdfs:comment "Flag indicating readiness for public promotion."@en ;
             rdfs:label "publishable"@en .


###  http://scimantic.io/unit
:unit rdf:type owl:DatatypeProperty ;
      rdfs:domain :Result ;
      rdfs:range xsd:string ;
      rdfs:label "unit"@en .


###  http://scimantic.io/value
:value rdf:type owl:DatatypeProperty ;
       rdfs:domain :Result ;
       rdfs:label "value"@en .


#################################################################
#    Classes
#################################################################

###  http://scimantic.io/Analysis
:Analysis rdf:type owl:Class ;
          rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
          rdfs:comment "The activity of processing a Dataset to produce a Result."@en ;
          rdfs:label "Analysis"@en .


###  http://scimantic.io/Assessment
:Assessment rdf:type owl:Class ;
            rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
            rdfs:comment "The activity of evaluating credibility or relevance of Evidence."@en ;
            rdfs:label "Evidence Assessment"@en .


###  http://scimantic.io/Dataset
:Dataset rdf:type owl:Class ;
         rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
         rdfs:comment "Raw data, observations, or measurements produced by execution."@en ;
         rdfs:label "Dataset"@en .


###  http://scimantic.io/Design
:Design rdf:type owl:Class ;
        rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ,
                        <http://www.w3.org/ns/prov#Plan> ;
        rdfs:comment "A specification of the experimental or computational method."@en ;
        rdfs:label "Study Design"@en .


###  http://scimantic.io/DesignPlanning
:DesignPlanning rdf:type owl:Class ;
                rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
                rdfs:comment "The activity of specifying a Design."@en ;
                rdfs:label "Design Planning"@en .


###  http://scimantic.io/Evidence
:Evidence rdf:type owl:Class ;
          rdfs:subClassOf <http://www.nanopub.org/nschema#Nanopublication> ,
                          <http://www.w3.org/ns/prov#Entity> ;
          rdfs:comment "A factual claim extracted from a source."@en ;
          rdfs:label "Evidence"@en .


###  http://scimantic.io/Execution
:Execution rdf:type owl:Class ;
           rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
           rdfs:comment "The activity of running a Design to produce a Dataset."@en ;
           rdfs:label "Execution"@en .


###  http://scimantic.io/Hypothesis
:Hypothesis rdf:type owl:Class ;
            rdfs:subClassOf <http://www.nanopub.org/nschema#Nanopublication> ,
                            <http://www.w3.org/ns/prov#Entity> ;
            rdfs:comment "A testable claim derived from evidence."@en ;
            rdfs:label "Hypothesis"@en .


###  http://scimantic.io/HypothesisFormation
:HypothesisFormation rdf:type owl:Class ;
                     rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
                     rdfs:comment "The activity of synthesizing Evidence into a Hypothesis."@en ;
                     rdfs:label "Hypothesis Formation"@en .


###  http://scimantic.io/LiteratureSearch
:LiteratureSearch rdf:type owl:Class ;
                  rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
                  rdfs:comment "The activity of searching for and extracting Evidence."@en ;
                  rdfs:label "Literature Search"@en .


###  http://scimantic.io/Parameter
:Parameter rdf:type owl:Class ;
           rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
           rdfs:comment "A configured parameter within a Design."@en ;
           rdfs:label "Design Parameter"@en .


###  http://scimantic.io/Question
:Question rdf:type owl:Class ;
          rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
          rdfs:comment "An interrogative sentence representing the research query."@en ;
          rdfs:label "Research Question"@en .


###  http://scimantic.io/QuestionFormation
:QuestionFormation rdf:type owl:Class ;
                   rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
                   rdfs:comment "The activity of creating a Research Question."@en ;
                   rdfs:label "Question Formation"@en .


###  http://scimantic.io/Result
:Result rdf:type owl:Class ;
        rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
        rdfs:comment "The outcome of an analysis activity."@en ;
        rdfs:label "Result"@en .


###  http://www.nanopub.org/nschema#Nanopublication
<http://www.nanopub.org/nschema#Nanopublication> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Activity
<http://www.w3.org/ns/prov#Activity> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Entity
<http://www.w3.org/ns/prov#Entity> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Plan
<http://www.w3.org/ns/prov#Plan> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#SoftwareAgent
<http://www.w3.org/ns/prov#SoftwareAgent> rdf:type owl:Class .


###  http://www.w3.org/ns/urref#UncertaintyEntity
<http://www.w3.org/ns/urref#UncertaintyEntity> rdf:type owl:Class .



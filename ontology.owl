    <!-- http://scimantic.io/ontology#accessLevel -->


    <owl:DatatypeProperty rdf:about="http://scimantic.io/ontology#accessLevel">
        <rdfs:domain rdf:resource="http://www.nanopub.org/nschema#Nanopublication"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Publishing scope (e.g., local, institutional, public).</rdfs:comment>
        <rdfs:label xml:lang="en">access level</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://scimantic.io/ontology#codeRepository -->


    <owl:DatatypeProperty rdf:about="http://scimantic.io/ontology#codeRepository">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/prov#SoftwareAgent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:label xml:lang="en">code repository</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://scimantic.io/ontology#commitHash -->


    <owl:DatatypeProperty rdf:about="http://scimantic.io/ontology#commitHash">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/prov#SoftwareAgent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">commit hash</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://scimantic.io/ontology#method -->


    <owl:DatatypeProperty rdf:about="http://scimantic.io/ontology#method">
        <rdfs:domain rdf:resource="http://scimantic.io/ontology#Design"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">method</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://scimantic.io/ontology#publishable -->


    <owl:DatatypeProperty rdf:about="http://scimantic.io/ontology#publishable">
        <rdfs:domain rdf:resource="http://www.nanopub.org/nschema#Nanopublication"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Flag indicating readiness for public promotion.</rdfs:comment>
        <rdfs:label xml:lang="en">publishable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://scimantic.io/ontology#unit -->


    <owl:DatatypeProperty rdf:about="http://scimantic.io/ontology#unit">
        <rdfs:domain rdf:resource="http://scimantic.io/ontology#Result"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">unit</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://scimantic.io/ontology#value -->


    <owl:DatatypeProperty rdf:about="http://scimantic.io/ontology#value">
        <rdfs:domain rdf:resource="http://scimantic.io/ontology#Result"/>
        <rdfs:label xml:lang="en">value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 

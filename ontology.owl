    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://scimantic.io/ontology#Analysis -->


    <owl:Class rdf:about="http://scimantic.io/ontology#Analysis">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:comment xml:lang="en">The activity of processing a Dataset to produce a Result.</rdfs:comment>
        <rdfs:label xml:lang="en">Analysis</rdfs:label>
    </owl:Class>
    


    <!-- http://scimantic.io/ontology#Assessment -->


    <owl:Class rdf:about="http://scimantic.io/ontology#Assessment">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:comment xml:lang="en">The activity of evaluating credibility or relevance of Evidence.</rdfs:comment>
        <rdfs:label xml:lang="en">Evidence Assessment</rdfs:label>
    </owl:Class>
    


    <!-- http://scimantic.io/ontology#Dataset -->


    <owl:Class rdf:about="http://scimantic.io/ontology#Dataset">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">Raw data, observations, or measurements produced by execution.</rdfs:comment>
        <rdfs:label xml:lang="en">Dataset</rdfs:label>
    </owl:Class>
    


    <!-- http://scimantic.io/ontology#Design -->


    <owl:Class rdf:about="http://scimantic.io/ontology#Design">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Plan"/>
        <rdfs:comment xml:lang="en">A specification of the experimental or computational method.</rdfs:comment>
        <rdfs:label xml:lang="en">Study Design</rdfs:label>
    </owl:Class>
    


    <!-- http://scimantic.io/ontology#DesignPlanning -->


    <owl:Class rdf:about="http://scimantic.io/ontology#DesignPlanning">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:comment xml:lang="en">The activity of specifying a Design.</rdfs:comment>
        <rdfs:label xml:lang="en">Design Planning</rdfs:label>
    </owl:Class>
    


    <!-- http://scimantic.io/ontology#Evidence -->


    <owl:Class rdf:about="http://scimantic.io/ontology#Evidence">
        <rdfs:subClassOf rdf:resource="http://www.nanopub.org/nschema#Nanopublication"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">A factual claim extracted from a source.</rdfs:comment>
        <rdfs:label xml:lang="en">Evidence</rdfs:label>
    </owl:Class>
    


    <!-- http://scimantic.io/ontology#Execution -->


    <owl:Class rdf:about="http://scimantic.io/ontology#Execution">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:comment xml:lang="en">The activity of running a Design to produce a Dataset.</rdfs:comment>
        <rdfs:label xml:lang="en">Execution</rdfs:label>
    </owl:Class>
    


    <!-- http://scimantic.io/ontology#Hypothesis -->


    <owl:Class rdf:about="http://scimantic.io/ontology#Hypothesis">
        <rdfs:subClassOf rdf:resource="http://www.nanopub.org/nschema#Nanopublication"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">A testable claim derived from evidence.</rdfs:comment>
        <rdfs:label xml:lang="en">Hypothesis</rdfs:label>
    </owl:Class>
    


    <!-- http://scimantic.io/ontology#HypothesisFormation -->


    <owl:Class rdf:about="http://scimantic.io/ontology#HypothesisFormation">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:comment xml:lang="en">The activity of synthesizing Evidence into a Hypothesis.</rdfs:comment>
        <rdfs:label xml:lang="en">Hypothesis Formation</rdfs:label>
    </owl:Class>
    


    <!-- http://scimantic.io/ontology#LiteratureSearch -->


    <owl:Class rdf:about="http://scimantic.io/ontology#LiteratureSearch">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:comment xml:lang="en">The activity of searching for and extracting Evidence.</rdfs:comment>
        <rdfs:label xml:lang="en">Literature Search</rdfs:label>
    </owl:Class>
    


    <!-- http://scimantic.io/ontology#Parameter -->


    <owl:Class rdf:about="http://scimantic.io/ontology#Parameter">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">A configured parameter within a Design.</rdfs:comment>
        <rdfs:label xml:lang="en">Design Parameter</rdfs:label>
    </owl:Class>
    


    <!-- http://scimantic.io/ontology#Question -->


    <owl:Class rdf:about="http://scimantic.io/ontology#Question">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">An interrogative sentence representing the research query.</rdfs:comment>
        <rdfs:label xml:lang="en">Research Question</rdfs:label>
    </owl:Class>
    


    <!-- http://scimantic.io/ontology#QuestionFormation -->


    <owl:Class rdf:about="http://scimantic.io/ontology#QuestionFormation">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:comment xml:lang="en">The activity of creating a Research Question.</rdfs:comment>
        <rdfs:label xml:lang="en">Question Formation</rdfs:label>
    </owl:Class>
    


    <!-- http://scimantic.io/ontology#Result -->


    <owl:Class rdf:about="http://scimantic.io/ontology#Result">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">The outcome of an analysis activity.</rdfs:comment>
        <rdfs:label xml:lang="en">Result</rdfs:label>
    </owl:Class>
    



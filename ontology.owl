     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://scimantic.io/ontology#">
        <terms:description xml:lang="en">A minimal domain ontology for representing the scientific method as provenance chains.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:title xml:lang="en">Scimantic Ontology</terms:title>
        <rdfs:seeAlso rdf:resource="http://www.w3.org/ns/prov#"/>
        <rdfs:seeAlso rdf:resource="http://www.w3.org/ns/urref#"/>
        <owl:versionInfo>0.1.0</owl:versionInfo>
    </owl:Ontology>
    



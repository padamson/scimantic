    <!-- http://scimantic.io/expectedOutcome -->


    <owl:ObjectProperty rdf:about="http://scimantic.io/expectedOutcome">
        <rdfs:domain rdf:resource="http://scimantic.io/Design"/>
        <rdfs:range rdf:resource="http://scimantic.io/Hypothesis"/>
        <rdfs:label xml:lang="en">expected outcome</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://scimantic.io/hasUncertainty -->


    <owl:ObjectProperty rdf:about="http://scimantic.io/hasUncertainty">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/urref#UncertaintyEntity"/>
        <rdfs:comment xml:lang="en">Links an entity to its uncertainty model.</rdfs:comment>
        <rdfs:label xml:lang="en">has uncertainty</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://scimantic.io/parameter -->


    <owl:ObjectProperty rdf:about="http://scimantic.io/parameter">
        <rdfs:domain rdf:resource="http://scimantic.io/Design"/>
        <rdfs:range rdf:resource="http://scimantic.io/Parameter"/>
        <rdfs:label xml:lang="en">parameter</rdfs:label>
    </owl:ObjectProperty>
    



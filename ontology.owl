    <!-- http://scimantic.io/ontology#expectedOutcome -->


    <owl:ObjectProperty rdf:about="http://scimantic.io/ontology#expectedOutcome">
        <rdfs:domain rdf:resource="http://scimantic.io/ontology#Design"/>
        <rdfs:range rdf:resource="http://scimantic.io/ontology#Hypothesis"/>
        <rdfs:label xml:lang="en">expected outcome</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://scimantic.io/ontology#hasUncertainty -->


    <owl:ObjectProperty rdf:about="http://scimantic.io/ontology#hasUncertainty">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/urref#UncertaintyEntity"/>
        <rdfs:comment xml:lang="en">Links an entity to its uncertainty model.</rdfs:comment>
        <rdfs:label xml:lang="en">has uncertainty</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://scimantic.io/ontology#parameter -->


    <owl:ObjectProperty rdf:about="http://scimantic.io/ontology#parameter">
        <rdfs:domain rdf:resource="http://scimantic.io/ontology#Design"/>
        <rdfs:range rdf:resource="http://scimantic.io/ontology#Parameter"/>
        <rdfs:label xml:lang="en">parameter</rdfs:label>
    </owl:ObjectProperty>
    


